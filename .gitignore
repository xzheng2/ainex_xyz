# Deny everything by default
*

# Allow .gitignore itself
!.gitignore

# Allow ROS workspace source
!docker/
!docker/ros_ws_src/
!docker/ros_ws_src/**

# Allow ROSA agent
!docker/rosa-agent/
!docker/rosa-agent/**
!docker/docker-compose.yml

# Allow Claude config (memory, settings, CLAUDE.md)
!.claude/
!.claude/projects/
!.claude/projects/-home-pi/
!.claude/projects/-home-pi/memory/
!.claude/projects/-home-pi/memory/**
!.claude/projects/-home-pi/CLAUDE.md
!.claude/settings.json
!.claude/settings.local.json

# Exclude generated/binary files within allowed paths
docker/ros_ws_src/**/__pycache__/
docker/ros_ws_src/**/*.pyc
docker/ros_ws_src/**/*.zip
docker/ros_ws_src/**/*.7z
docker/ros_ws_src/**/*.bag
docker/ros_ws_src/**/*.so
docker/ros_ws_src/**/core
docker/ros_ws_src/**/build/

# Exclude session-specific notes
docker/ros_ws_src/**/*_this_session.md

# Exclude generated Python package metadata
docker/rosa-agent/**/*.egg-info/


# Exclude secrets and generated files in rosa-agent
docker/rosa-agent/.env
docker/rosa-agent/**/__pycache__/
docker/rosa-agent/**/*.pyc
