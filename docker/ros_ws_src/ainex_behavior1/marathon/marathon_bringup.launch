<?xml version="1.0"?>
<!--
  Minimal bringup for HuroCup marathon event.

  Nodes started (10 total):
    Camera pipeline  (3): usb_cam, nodelet_manager, rectify_color
    Base hardware    (5): sensor, ros_robot_controller, ainex_controller,
                          imu_calib, imu_filter
    Vision           (1): color_detection  (publishes /object/pixel_coords)
    Monitoring       (1): web_video_server

  Excluded vs full bringup.launch:
    - joystick / joystick_control   (manual input, not needed for autonomous run)
    - rosbridge_websocket / rosapi  (phone-app bridge, not needed)
    - face_detect                   (unused by marathon)
    - app_node                      (GUI app controller, causes AttributeError spam)
-->
<launch>
    <arg name="camera_name" default="camera"/>
    <arg name="image_topic" default="image_raw"/>

    <!-- Camera: usb_cam + nodelet manager + rectify_color -->
    <include file="$(find ainex_peripherals)/launch/usb_cam_with_calib.launch">
        <arg name="camera_name" value="$(arg camera_name)"/>
        <arg name="image_topic" value="$(arg image_topic)"/>
    </include>

    <!-- Base: sensor + ros_robot_controller + ainex_controller + imu_calib + imu_filter -->
    <include file="$(find ainex_bringup)/launch/base.launch"/>

    <!-- Color detection: publishes /object/pixel_coords consumed by marathon_bt_node -->
    <include file="$(find ainex_example)/scripts/color_detection/color_detection_node.launch">
        <arg name="enable_camera"    value="false"/>
        <arg name="enable_web_video" value="false"/>
        <arg name="enable_display"   value="false"/>
    </include>

    <!-- Web video server: monitor camera feed at http://<robot-ip>:8080 -->
    <node name="web_video_server" pkg="web_video_server" respawn="true"
          respawn_delay="2" type="web_video_server" output="screen"/>
</launch>
