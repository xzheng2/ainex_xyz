<?xml version="1.0"?>
<!--apriltag追踪-->
<launch>
    <arg name="start"  default="true"/>

    <!--apriltag识别节点-->
    <include file="$(find ainex_example)/scripts/apriltag_detection/apriltag_detection_node.launch"/>

    <include file="$(find ainex_bringup)/launch/base.launch"/>

    <!--apriltag追踪-->
    <node pkg="hurocup2025" type="sprint_node.py" name="sprint" output="screen">
        <param name="start"  value="$(arg start)"/>
    </node>
</launch>
