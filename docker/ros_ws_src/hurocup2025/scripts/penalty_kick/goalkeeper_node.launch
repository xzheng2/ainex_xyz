<?xml version="1.0"?>
<!--守门-->
<launch>
    <arg name="color"  default="blue"/>
    <arg name="start"  default="true"/>

    <!--颜色识别节点-->
    <include file="$(find hurocup2025)/scripts/penalty_kick/color_detection_node.launch"/>

    <include file="$(find ainex_bringup)/launch/base.launch"/>

    <!--自动踢球-->
    <node pkg="hurocup2025" type="goalkeeper_node.py" name="goalkeeper" output="screen">
        <param name="start"  value="$(arg start)"/>
        <param name="color"  value="$(arg color)"/>
    </node>
</launch>
