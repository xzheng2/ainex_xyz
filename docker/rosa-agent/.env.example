# Copy this file to .env and fill in your values.
# .env is NOT committed to git (see .gitignore).

# ── LLM Provider (pick ONE) ──────────────────────────────────────────────────
# Option A: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Option B: Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-05-01-preview

# Option C: Ollama (local, no API key needed)
# host.docker.internal does NOT resolve in host network mode — use localhost
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── ROS Network ──────────────────────────────────────────────────────────────
# Both ainex and rosa-agent use host networking; roscore is on localhost
ROS_MASTER_URI=http://127.0.0.1:11311

# ── Safety ───────────────────────────────────────────────────────────────────
# Keep this "false" until write operations are explicitly audited and approved
AINEX_WRITE_ENABLED=false
